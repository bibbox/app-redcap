				<textElement verticalAlignment="Middle" markup="html">
					<font size="14" isBold="true" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[5.1.2. Selection of venous whole blood collection tube:]]></text>
			</staticText>
		</band>
		<band height="105">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="105" uuid="d6bae1eb-a26f-4f9c-9cfb-73cdd2f1dfca"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[In general, blood collection tubes containing blood cellular RNA profile stabilisers should be used due to the high instability of blood cellular RNA profiles in individual donors/patients. Tubes that do not contain any blood cellular RNA profile stabilisers should only be used if the specific blood cellular RNA molecule or profile to be analysed is stable after blood draw or if the analytical test to be carried out allows the use of such tubes.]]></text>
			</staticText>
		</band>
