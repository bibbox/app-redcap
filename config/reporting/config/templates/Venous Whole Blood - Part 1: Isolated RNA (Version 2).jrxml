			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="db321ba0-7bb3-4b05-be55-da0d3fe536a1"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The storage duration allowed at 2-8 °C or when using wet ice is highly dependent on the stability of the individual RNA molecules and their cellular quantities to be analysed in the analytical test. It may vary between several minutes and more than 24h.]]></text>
			</staticText>
		</band>
