					<font size="14" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[<font size='4' color='#004280'><b>REPORT</b></font><br><font size='2' color='#004280'>SELF-ASSESSMENT SURVEY<br><font size='1' color='#004280'>Venous Whole Blood - Part 1: Isolated RNA (Version 2)</font>]]></text>
			</staticText>
		</band>
