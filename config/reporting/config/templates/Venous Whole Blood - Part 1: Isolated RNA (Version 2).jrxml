				</textElement>
				<text><![CDATA[5.1.4. Information on the primary venous whole blood samples and storage at the collection site:]]></text>
			</staticText>
		</band>
		<band height="75">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="1accb8b5-a5d6-4bf3-a42a-4c15869ef86a"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Since it is usually not clear which individual RNA molecules will be analysed after samples have been archived at a biobank, tubes without blood cellular RNA profile stabilisers should not be used in biobanking.]]></text>
			</staticText>
		</band>
