				<textElement verticalAlignment="Middle" markup="html">
					<font size="14" isBold="true" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[6.6. Storage conditions ]]></text>
			</staticText>
		</band>
		<band height="90">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="90" uuid="a14de447-3fd7-4929-b648-c60260f08eb1"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[FFPE tissue samples can be stored in several ways, e.g. as blocks, cut sections or as multi tissue arrays. Storage time may influence the retrieval of a protein or group of proteins over time and thus impact the subsequent proteomic measurement. Protein yield may decrease with increasing storage time.]]></text>
			</staticText>
		</band>
		<band height="70" splitType="Prevent">
