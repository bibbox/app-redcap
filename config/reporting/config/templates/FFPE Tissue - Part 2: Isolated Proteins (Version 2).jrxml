				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="5144efcb-e96e-4104-9788-47fdac5b94fb"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[For archiving (i.e. for several years), should be at -20°C, -70°C or below. Avoid more than two freeze-thaw cycles, use aliquots instead. If lyophilised, protein can be stored for several years at 4°C or -20°C.]]></text>
			</staticText>
		</band>
