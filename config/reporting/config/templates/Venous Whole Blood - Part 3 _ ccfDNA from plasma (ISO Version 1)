		<band height="90">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="90" uuid="2917ed87-68df-4c9e-8a85-92b341ef73dc"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Molecule profiles can change during primary sample collection, which is why transport, storage and processing may influence research results. Standardising the entire process from sample collection to the selection of appropriate analysis methods is therefore crucial.  ]]></text>
			</staticText>
		</band>
		<band height="120">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="120" uuid="d074226c-5c91-4666-b9c8-d004645c932c"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The International Organization for Standardization published a standard to determine influencing factors and provide recommendations for the handling, documentation and processing of venous whole blood intended for circulating cell free DNA analysis from plasma (ISO 20186-3:2019, Molecular in vitro diagnostic examinations - Specifications for pre-examination processes for venous whole blood - Part 3: Isolated circulating cell free DNA from plasma). For further details, please visit the <a href="https://www.iso.org/standard/69800.html">ISO website</a>.]]></text>
			</staticText>
		</band>
		<band height="60">
