					<font size="14" isBold="true" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[5.1.4. Information on the primary venous whole blood samples and storage at the collection site:]]></text>
			</staticText>
		</band>
		<band height="60">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="60" uuid="6e6f69e4-8359-4103-a742-fcc6bae5d6af"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Blood cell lysis after blood collection contaminates the sample with cellular DNA and can affect the validity and reliability of the analytical test result. ]]></text>
			</staticText>
		</band>
