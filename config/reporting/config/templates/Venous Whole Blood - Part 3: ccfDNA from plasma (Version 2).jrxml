				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[EDTA blood collection tubes should be preferred over other collection tubes. Induced clotting processes in serum tubes can lead to leucocytes lysis and should therefore be avoided. EDTA blood collection tubes must be handled as follows:]]></text>
			</staticText>
		</band>
		<band height="80" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="80" uuid="46deacab-5237-472b-93cd-43bbaf297f87"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para 3) First centrifugation step: EDTA was centrifuged at 1600g to 2500g at 2-8°C for 10 min
<br><font color="#004280">should</font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="9dc56972-4f5b-4e46-80b0-841c1af758be"/>
