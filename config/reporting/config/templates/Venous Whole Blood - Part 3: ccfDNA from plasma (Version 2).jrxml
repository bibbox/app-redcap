		<band height="105">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="105" uuid="fa9bfc54-93bf-4b4d-a358-6fe51ff64bf6"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[If the blood collection tube manufacturer or the analytical test provider has instructions on packaging, samples shall be transported accordingly. If there are no such instructions, samples should be packed in tissues, airbags, paper or the like to protect them from shaking/dropping during transport. Samples must not be frozen or shaken vigorously.]]></text>
			</staticText>
		</band>
		<band height="60">
			<staticText>
