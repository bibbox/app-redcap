					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[In general, the duration of transport to the laboratory needs to be added when calculating the total storage duration.]]></text>
			</staticText>
		</band>
