		<band height="60">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="60" uuid="b972ecb6-d841-438f-baaa-a1ed62901846"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Until clean plasma is generated, special care needs to be taken to avoid lysis of blood cells. Primary samples must not be frozen or shaken vigorously.]]></text>
			</staticText>
		</band>
		<band height="69">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="69" uuid="5a4817c2-7660-470c-a86a-283461e3f732"/>
