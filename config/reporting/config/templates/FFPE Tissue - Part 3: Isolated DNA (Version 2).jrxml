				</textElement>
				<text><![CDATA[6.8. Quantity and quality assessment of DNA]]></text>
			</staticText>
		</band>
		<band height="75">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="9789d0b8-98d9-4566-91b2-9ec6b0837b08"/>
