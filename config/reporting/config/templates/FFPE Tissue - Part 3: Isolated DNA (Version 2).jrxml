					<printWhenExpression><![CDATA[$F{ffpe_dna_085_v2_v2}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
		</band>
		<band height="100" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="100" uuid="b8d5d42d-9ce4-4ee8-a2c7-b307eedb0a82"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[3. Did you make parallel haematoxylin/eosin (H&E) stained sections to identify, select and control dissection of unstained specimens for subsequent protein purification? 
<br><font color="#004280">should</font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="ef71c6f7-c13b-40f4-9f41-b33f19f57e2d"/>
