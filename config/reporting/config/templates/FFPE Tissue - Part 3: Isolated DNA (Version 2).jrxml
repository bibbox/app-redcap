				<reportElement positionType="Float" x="25" y="0" width="545" height="45" uuid="bd299eb5-e683-48a7-ac59-6c2c4ce072d1"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Using a laboratory's protocol, DNA isolation included the following steps:]]></text>
			</staticText>
		</band>
		<band height="55" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="55" uuid="6c733784-2f3e-4447-a676-c636608aebe6"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[1. Paraffin was removed from freshly cut FFPE sections
<br><font color="#004280">should</font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="05f06d8b-6316-466e-a16a-1a0d83d1203d"/>
