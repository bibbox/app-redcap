				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Quantification: absorption (A260), spectroflurometry or a genomic specific qPCR assay
<br><font color="#004280">should</font>]]></text>
