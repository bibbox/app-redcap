				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[No]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="10" uuid="2bbf2bff-5814-4afe-a4f4-731e424af786"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="10" uuid="240a18f9-9ab7-4028-9965-9dceda24b25f">
					<printWhenExpression><![CDATA[$F{ffpe_dna_084_v2_v2}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
