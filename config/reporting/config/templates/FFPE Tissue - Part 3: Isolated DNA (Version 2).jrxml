				<reportElement x="25" y="0" width="272" height="70" uuid="49f62839-4783-4ff8-90bb-fd42accc4a48"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[2. Did you use freshly cut sections (up to 10 µm) from trimmed FFPE blocks for DNA isolation?
<br><font color="#004280">should</font>]]></text>
			</staticText>
