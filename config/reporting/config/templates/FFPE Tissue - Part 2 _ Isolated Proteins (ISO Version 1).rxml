				<reportElement x="322" y="96" width="12" height="24" uuid="a00881cc-e023-4578-9d89-ea30d3709807">
					<printWhenExpression><![CDATA[$F{ffp2_v3_690_para2_v1___3}.trim().equalsIgnoreCase("Western blot (e.g. ß-actin)")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checkbox_checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="337" y="120" width="210" height="24" uuid="54b5f816-5444-4339-b234-9dd3a371d082"/>
				<textElement verticalAlignment="Top" markup="html">
