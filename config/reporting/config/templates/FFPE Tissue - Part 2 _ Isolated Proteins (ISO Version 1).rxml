			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="15" uuid="437a8c3f-cc6f-4048-8b3b-f78a5028bef0">
					<printWhenExpression><![CDATA[$F{ffp2_v3_684_c_v1}.trim().equalsIgnoreCase("Yes")]]></printWhenExpression>
				</reportElement>
