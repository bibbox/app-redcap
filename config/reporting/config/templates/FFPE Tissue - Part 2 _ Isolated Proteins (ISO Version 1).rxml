				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[The sample was boiled for 20min, incubated at 80 °C for 2h, centrifuged and transferred into a fresh reaction tube)<br><font color="#004280">should</font><br>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="d1d80510-721a-4c7e-9928-d6542fab6c83"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
