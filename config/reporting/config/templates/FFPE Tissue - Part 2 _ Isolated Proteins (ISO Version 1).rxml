			</image>
			<staticText>
				<reportElement x="337" y="96" width="210" height="24" uuid="2fa59701-9b73-47c3-93d7-72c2bf5ab239"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Western blot (e.g. ß-actin)]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="96" width="12" height="24" uuid="369dea8b-60e9-4bee-9fa0-269dc4be063b"/>
