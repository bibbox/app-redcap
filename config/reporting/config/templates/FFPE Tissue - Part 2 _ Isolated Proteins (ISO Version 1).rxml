				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para 4) For protein isolation, freshly prepared FFPE sections were used and documented<br><font color="#004280">should</font><br>]]></text>
			</staticText>
