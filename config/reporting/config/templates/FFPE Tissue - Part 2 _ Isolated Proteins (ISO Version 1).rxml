		</band>
		<band height="144" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="144" uuid="c2a88a9a-cc2f-4c18-b93c-cf14f3546049"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para 2) Such procedures to determine the purity and integrity may include one or more of the following techniques, depending on the specific examination  test:]]></text>
			</staticText>
			<staticText>
				<reportElement x="337" y="0" width="210" height="48" uuid="70321171-5b1c-4203-8f56-7c47c41d50ae"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Sodium Dodecyl Sulfate Polyacrylamide Gel Electrophoresis (SDS-PAGE) and Coomassie blue or silver staining]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="12" height="48" uuid="fbbfb072-d14d-41e7-a5fe-ec4047aa3007"/>
				<imageExpression><![CDATA["checkbox_unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="12" height="48" uuid="1b3a3a92-e4ef-405a-addf-ea899f05d05e">
					<printWhenExpression><![CDATA[$F{ffp2_v3_690_para2_v1___0}.trim().equalsIgnoreCase("Sodium Dodecyl Sulfate Polyacrylamide Gel Electrophoresis (SDS-PAGE) and Coomassie blue or silver staining")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checkbox_checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="337" y="48" width="210" height="24" uuid="74b8ef84-a67e-4d42-b0ed-d613562488d8"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[capillary electrophoresis]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="48" width="12" height="24" uuid="521f2c3d-c925-49bb-b727-e8818551cb30"/>
				<imageExpression><![CDATA["checkbox_unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="48" width="12" height="24" uuid="cf5c515b-1056-45b1-964d-a67e47506097">
					<printWhenExpression><![CDATA[$F{ffp2_v3_690_para2_v1___1}.trim().equalsIgnoreCase("capillary electrophoresis")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checkbox_checked.png"]]></imageExpression>
			</image>
			<staticText>
