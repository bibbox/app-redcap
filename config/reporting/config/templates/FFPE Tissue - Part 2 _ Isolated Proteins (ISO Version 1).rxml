		<band height="96" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="96" uuid="f8a17960-fd1c-454b-839b-2a881d6e1f2b"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para 3) Determining total protein concentration may include one or more of the following techniques, depending on the specific examination test:]]></text>
