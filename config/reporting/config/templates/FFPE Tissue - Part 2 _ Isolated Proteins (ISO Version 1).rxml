				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[The sample was prepared using a microtome and a suitable number of 5-10 µm-thick sections was prepared<br><font color="#004280">should</font><br>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="d11b2420-2f24-4bcb-9ccc-0b64a24304b1"/>
