				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para 3) For protein isolation from FFPE tissues, a strong detergent and exposure to high temperatures were used for an efficient reversal of formaldehyde-based protein crosslinks<br><font color="#004280">should</font><br>]]></text>
			</staticText>
			<staticText>
