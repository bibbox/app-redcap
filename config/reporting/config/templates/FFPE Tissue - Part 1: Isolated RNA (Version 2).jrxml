					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The RNA quantity and quality should be checked according to the diagnostic kit manufacturers instruction, or according to validated procedures by generally accepted physical, chemical and biochemical procedures, may include the following:]]></text>
			</staticText>
		</band>
		<band height="65" splitType="Prevent">
