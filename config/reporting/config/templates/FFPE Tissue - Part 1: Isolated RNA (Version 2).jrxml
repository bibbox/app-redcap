				</textElement>
				<text><![CDATA[6.8. Quantity and quality assessment of RNA  ]]></text>
			</staticText>
		</band>
		<band height="75">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="ce23711d-a526-4bd5-a888-5e64643f095c"/>
