				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Archived tissue blocks were trimmed before taking sections for RNA isolation, and this was documented
<br><font color="#004280">should</font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="d65cf4a4-1ac4-4ccc-89d8-67b1d96e5224"/>
