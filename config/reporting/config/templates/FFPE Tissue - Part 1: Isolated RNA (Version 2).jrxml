				<reportElement positionType="Float" x="25" y="0" width="545" height="90" uuid="3b486757-ba87-4c58-86d6-013f90c0c433"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The optimal formalin fixation duration can vary depending on tissue type and size. For larger surgical specimen inhomogeneous fixation can occur before the grossing process due to slow penetration of formaldehyde from the surface of the tissue to the interior.]]></text>
			</staticText>
		</band>
