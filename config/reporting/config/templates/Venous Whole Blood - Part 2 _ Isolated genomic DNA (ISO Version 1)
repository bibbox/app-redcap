		<band height="90">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="90" uuid="d9c561f4-c63f-4e2a-90fa-811e1c332410"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Molecule profiles can change during primary sample collection, which is why transport, storage and processing may influence research results. Standardising the entire process from sample collection to the selection of appropriate analysis methods is therefore crucial. ]]></text>
			</staticText>
		</band>
		<band height="120">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="120" uuid="40cf34e0-9813-4171-8036-e3acdb033d6c"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The International Organization for Standardization published a standard to determine influencing factors and provide recommendations for the handling, documentation and processing of venous whole blood intended for genomic DNA analysis (20186-2:2019, Molecular in vitro diagnostic examinations - Specifications for pre-examination processes for venous whole blood - Part 2: Isolated genomic DNA). For further details, please visit the <a href="https://www.iso.org/standard/69799.html">ISO website</a>.]]></text>
			</staticText>
		</band>
		<band height="60">
			<staticText>
