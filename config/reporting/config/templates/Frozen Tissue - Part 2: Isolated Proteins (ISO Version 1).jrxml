				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Accidentally freezing the tissue (e.g. by using cool packs in a wrong manner) can lead to protein degradation when the tissue thaws. It can also impact the morphological characterization.]]></text>
			</staticText>
		</band>
		<band height="70" splitType="Prevent">
