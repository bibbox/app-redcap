		<band height="75">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="493f1c9d-82c9-43f2-ade1-837903f4d92b"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The use of products from different manufacturers can compromise results as the products may not be compatible. They should be used for diagnostic testing only if the components have been tested together and validated to work satisfactorily.]]></text>
			</staticText>
		</band>
		<band height="52">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="52" uuid="0a119062-bfb6-4129-ab2c-e3ba06ac5eba"/>
				<textElement verticalAlignment="Middle" markup="html">
					<font size="14" isBold="true" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[6.6. Quantity  and quality assessment of isolated  proteins]]></text>
			</staticText>
		</band>
		<band height="90">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="90" uuid="9e13f2ab-28f3-4a72-a4e9-b574bad1e81d"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Protein quality and quantity should be checked according to the diagnsotic kit manaufacturer's instructions, if not available, by generally accepted physical, chemical or biochemical procedures e.g. Western blot, Bradford assay, and/or by suitable controls as part of the examination.]]></text>
			</staticText>
		</band>
		<band height="60">
			<staticText>
