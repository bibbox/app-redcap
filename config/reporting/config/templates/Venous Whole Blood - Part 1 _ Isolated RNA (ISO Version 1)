		<band height="90">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="90" uuid="cf278d25-0f91-4a0b-aabf-599d50a27bad"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Molecule profiles can change during primary sample collection, which is why transport, storage and processing may influence research results. Standardising the entire process from sample collection to the selection of appropriate analysis methods is therefore crucial. ]]></text>
			</staticText>
		</band>
		<band height="120">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="120" uuid="63c258fd-22f2-4173-afed-875749c0da9a"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The International Organization for Standardization published a standard to determine influencing factors and provide recommendations for the handling, documentation and processing of venous whole blood intended for cellular RNA analysis (ISO 20186-1, Molecular in vitro diagnostic examinations - Specifications for pre-examination processes for venous whole blood - Part 1: Isolated cellular RNA). For further details, please visit the <a href="https://www.iso.org/standard/67217.html">ISO website</a>.]]></text>
			</staticText>
		</band>
		<band height="60">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="60" uuid="0523a591-dbe2-492b-a0a8-2e5c430111c2"/>
