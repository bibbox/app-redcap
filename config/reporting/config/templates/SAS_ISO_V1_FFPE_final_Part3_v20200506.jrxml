				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[e) Was isolation performed in a different environment than amplification (to avoid cross-contamination with amplified material)?<br /><br /><font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="95bce0a9-722e-4e3b-b283-36f6f7c772c7"/>
