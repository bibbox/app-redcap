				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="4a18f943-a9c7-420c-abe0-fdb23411c664">
					<printWhenExpression><![CDATA[$F{ffp3_v3_684_b_v1}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
