				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para2) Paraffin blocks were stored dry, at or below room temperature, and this was documented <br /><br /> <font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="c0e3f972-bba1-4393-a763-593b277fe7dd"/>
