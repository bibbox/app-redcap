				</textElement>
				<text><![CDATA[Microdissection of tissue should be considered to select or enrich for certain cellular features of a disease]]></text>
			</staticText>
		</band>
		<band height="62">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="62" uuid="77e43ce0-5fc1-49e6-a446-37b436c141c0"/>
