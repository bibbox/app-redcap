		<band height="94">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="94" uuid="ce2900e6-aed3-40cf-9e40-75fc3e90c7f1"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Formalin fixation has a negative impact on DNA integrity and reliability of DNA quality measurements. Chemical modifications caused by formaldehyde cannot be reliably detected in standard quality control assays such as elecrophoretic DNA fragment length measurement, but they can interfere with the enzymatic examination.]]></text>
			</staticText>
		</band>
