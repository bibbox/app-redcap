		<band height="100" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="100" uuid="b1d9835b-cdea-442a-a7ac-b8ac43b27f86"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[d) For all DNA isolation procedures from FFPE tissues, measures were included to reverse the formaldehyde modifications, such as nucleic acids and protein-DNA crosslinks, without further DNA degradation.<br /><br /><font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="be50182d-6f7d-4c8f-865a-fad32801f6e8"/>
