					<font size="12"/>
				</textElement>
				<text><![CDATA[b) Fixation starting time was documented <br /><br /> <font color="orange"><b>'shall'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="9c86c38a-f4b2-430c-9983-befa52713202"/>
