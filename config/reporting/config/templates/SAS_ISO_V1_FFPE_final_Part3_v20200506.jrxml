				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[a) For a tissue thickness of up to 5 mm, the fixation duration was 12-24 h in standard buffered formalin solution? <br /><br /> <font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="07de185a-af2b-46bc-8bf8-3eddac9a3059"/>
