				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
		</band>
		<band height="42" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="42" uuid="f1cd41a6-ab50-4a84-8586-adb4af1603c2"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[c) Heat incubation for up to 1h at 90Â°C?<br /><br /><font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="58995831-b20a-4dda-86e6-6c7c19720585"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Yes]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="8c0c9c38-7b7c-4f4a-a933-cedecde4153c"/>
