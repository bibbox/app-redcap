			</image>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="d96125fc-dbb0-458f-a3fd-c52ac0ab340e">
					<printWhenExpression><![CDATA[$F{ffp3_v3_684_c_v1}.trim().equalsIgnoreCase("Yes")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="335" y="16" width="16" height="16" uuid="544c2908-9b94-4926-834a-8bbb0309774e"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[No]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="d3cf93e2-2f36-4b64-99c1-d77a6f7ee70e"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="3bcb5223-f923-4d40-8bc7-7a08d9319bab">
					<printWhenExpression><![CDATA[$F{ffp3_v3_684_c_v1}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
		</band>
		<band height="68" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="68" uuid="10f94d5a-bdbd-49d0-a598-c84af8e19cd8"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[d) Optional: Incubation with Rnase A was performed, in case RNA-free genomic DNA is required<br /><br /><font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="1a24d043-b58e-4c78-859a-d52049877eaa"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Yes]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="f8de3c4f-1171-4024-a756-c2a7ad2b83eb"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="e7246c34-9b8d-4e33-a641-fc7da310d965">
					<printWhenExpression><![CDATA[$F{ffp3_v3_684_d_v1}.trim().equalsIgnoreCase("Yes")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="335" y="16" width="16" height="16" uuid="2a3e1198-75a7-4f4a-8595-68f32bfbff76"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[No]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="b8873cbb-7853-40f0-b62f-1b74132196f9"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="40279377-4b75-4029-ae43-3bc9e060b81e">
					<printWhenExpression><![CDATA[$F{ffp3_v3_684_d_v1}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
		</band>
		<band height="94">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="94" uuid="15e79f36-2108-4a81-a43b-d0cc56a5f888"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[For laboratory developed methods, it can be required to incorporate an RNase digestion step, if a too high amount of RNA, disturbing the examination test, is co-purified with the DNA. Co-purified RNA, even after digestion, can lead to over quantification of DANN yield by spectrophotometric methods. This over quantification and the actual presence of RNA can also interfere with examination test.]]></text>
			</staticText>
		</band>
		<band height="78">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="78" uuid="3add2061-109c-4dbe-ac5c-7166c3878d9e"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Co-purified RNA, even after digestion, can lead to over quantification of DANN yield by spectrophotometric methods. This over quantification and the actual presence of RNA can also interfere with examination test.]]></text>
			</staticText>
		</band>
		<band height="68" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="68" uuid="70d110fd-eb56-4114-bb02-4dfb275a600c"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[e) DNA was extracted from lysate with e.g. phenol/chloroform or using commercial kits for DNA purification from FFPE tissue<br /><br /><font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="7c8bbfeb-5b57-4f7b-a94e-6b79b45fcbfa"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Yes]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="c472d004-ba98-4ec9-a857-95fd2cbc4129"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="6324e663-e057-4ca5-a371-b34d1014bd8b">
					<printWhenExpression><![CDATA[$F{ffp3_v3_684_e_v1}.trim().equalsIgnoreCase("Yes")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="335" y="16" width="16" height="16" uuid="654fffe0-d734-477a-9e4b-250027ed6d6f"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[No]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="55b16898-d8b5-40f6-bf33-77c5da16a430"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="c63b0628-6cca-4f71-ad5c-4eca09b349fd">
					<printWhenExpression><![CDATA[$F{ffp3_v3_684_e_v1}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
		</band>
		<band height="54">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="54" uuid="219d9ab9-aa09-4d89-afe0-1f2f9c0dac5b"/>
				<textElement verticalAlignment="Middle" markup="html">
					<font size="14" isBold="true" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[6.9. Quality assessment of isolated proteins]]></text>
			</staticText>
		</band>
		<band height="62">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="62" uuid="9867c997-4975-4c0b-ac10-091bf865e4fe"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[DNA quality and quantity should be checked according to the diagnsotic kit manaufacturer's instructions, if not available, by generally accepted physical, chemical or biochemical procedures.]]></text>
			</staticText>
		</band>
		<band height="62">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="62" uuid="eeb7236f-4a68-45c6-8dd4-8935ec35d5c4"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[DNA quantity and quality by one or more of these methods checked (according to manufacturers instructions or validated protocol):]]></text>
			</staticText>
		</band>
		<band height="68" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="68" uuid="c58a6365-ee60-410e-b730-7e59c2859eb4"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[a) Quantification: absorbance measurements (A260) or spectroflurometry or a genomic specific qPCR assay<br /><br /><font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="cf05a765-b97a-435f-95c2-b10a609489f2"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Yes]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="997a5316-2007-4e46-a709-a425fae36bb5"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="16" uuid="9cbd73b1-3af4-44a7-890b-876e0e3cbc2d">
					<printWhenExpression><![CDATA[$F{ffp3_v3_690_a_v1}.trim().equalsIgnoreCase("Yes")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="335" y="16" width="16" height="16" uuid="971d2e92-8b19-4ac2-a535-8ead6d63e0fe"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[No]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="8cb03534-5d8f-42c1-8cd9-702d3e897248"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="16" uuid="d5de4cbe-5935-489d-b037-cb5f7c12e0f9">
					<printWhenExpression><![CDATA[$F{ffp3_v3_690_a_v1}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="335" y="32" width="79" height="16" uuid="6f225677-0682-4dce-9f3a-f96e4c8e3803"/>
				<textElement verticalAlignment="Top" markup="html">
