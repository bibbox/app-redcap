		<band height="54">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="54" uuid="b5b2a58c-7f35-4f17-b617-8b0353ba94fb"/>
				<textElement verticalAlignment="Middle" markup="html">
					<font size="14" isBold="true" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[6.8.2. General information for DNA isolation procedures:]]></text>
			</staticText>
		</band>
		<band height="94">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="94" uuid="2d3f2ab1-78ac-4e11-aef1-fd2403145850"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[para1) Formalin fixation introduces covalent modifications to DNA by addition of mono-methylol groups. In next steps electrophilic addition of N-methylol on an amino base leads to the formation of methylene bridges between two amino groups.  Formaldehyde introduces chemical modifications interfering with enzymatic reactions in subsequent molecular examinations e.g. DNA polymerase.]]></text>
			</staticText>
		</band>
		<band height="68" splitType="Prevent">
			<staticText>
