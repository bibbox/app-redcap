				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[c) Parallel haematoxylin/eosin (H&E) stained sections to identify, select and control dissection of unstained specimens for subsequent protein purification, used?<br /><br /><font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
