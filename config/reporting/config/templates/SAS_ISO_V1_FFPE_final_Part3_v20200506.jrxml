					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Depending on local procedures, the selection of approporiate parts of the speciemen can also be done outside of the laboratory, e.g. in the operating theatre (see 5.1.3)]]></text>
			</staticText>
		</band>
		<band height="116" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="116" uuid="91a858b5-8126-46a7-b8ca-61ce3ae44fb5"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[For macroscopic evaluation before and/or after formalin fixation: a check of the clinical information of the specimen (e.g. type, size, number), hospital admission number and/or pathology case number and/or donor/patient ID, name and date of birth of patient and type of tissue was checked <br /><br /> <font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="d19708ad-7f12-476e-8c30-8a10551322b2"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Yes]]></text>
			</staticText>
			<image vAlign="Top">
