		<band height="75">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="8079e726-342f-48d2-9561-83d3fe39d304"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[For archiving (i.e. for several years), should be at at -20°C, -70°C or below. Avoid more than two freeze-thaw cycles, use aliquots instead. If lyophilised, protein can be stored for several years at 4°C or -20°C.]]></text>
			</staticText>
		</band>
