					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The genomic DNA quantity and quality should be checked either according to the manufacturers' instructions or according to validated procedures following accepted physical, chemical and biochemical procedures.]]></text>
			</staticText>
		</band>
