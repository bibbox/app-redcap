				</textElement>
				<text><![CDATA[6.5. Isolation of total RNA
<br>
<br>6.5.1. General information for RNA isolation procedures]]></text>
			</staticText>
		</band>
		<band height="75">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="75" uuid="c4d9c4db-57a8-40ca-a1b7-fc936ebf45a4"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Freezing of tissue may result in the disruption of cellular membranes and organelles within the tissue. As a consequence, after thawing enzymes may be released and activated which may lead to degradation of RNA.]]></text>
			</staticText>
		</band>
