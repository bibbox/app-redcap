		<band height="85" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="85" uuid="b0cf2256-16bf-43e5-a417-4879689cc2bc"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para 1) Venous blood collection tube was selected according to the requirements of the analytical test and pre-analytical preparation
<br><font color="#ec6607">shall</font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="1f5844ea-9c66-4436-a552-9253aa9b8d0a"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Yes]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="10" uuid="fcf41a1a-81dd-4507-8594-29da2c9b776b"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="10" uuid="3b422d19-769f-40cd-b917-01a4ced02402">
					<printWhenExpression><![CDATA[$F{metabolomics_serum_033_v2_v2_v2}.trim().equalsIgnoreCase("Yes")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="335" y="16" width="17" height="15" uuid="200fd94a-2a27-4cd5-a23b-b9b35eea95ad"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[No]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="10" uuid="ca869020-ced8-4baf-82a9-4c4efe8e3128"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
			<image vAlign="Top">
				<reportElement x="322" y="16" width="10" height="10" uuid="96be77bc-6a9d-4e9b-8a7d-0f6bf0f6a85c">
					<printWhenExpression><![CDATA[$F{metabolomics_serum_033_v2_v2_v2}.trim().equalsIgnoreCase("No")]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA["checked.png"]]></imageExpression>
			</image>
		</band>
		<band height="135">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="135" uuid="7a42d840-3a66-43d7-b82f-367a9ebfdd16"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The choice of a specific tube for harvesting plasma or serum depends on the requirements of the subsequent metabolic profile analysis. 
<br>
<br>Plasma: EDTA, sodium fluoride or citrate can be used as anticoagulants. 
<br>EDTA is preferred for NMR-based metabolomics and most MS studies. 
<br>
<br>Heparin-based anticoagulants shall be avoided for NMR analysis.]]></text>
			</staticText>
		</band>
		<band height="40" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="40" uuid="faa875a5-cb7d-4678-b2ab-9e3d40fa5870"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[What kind of blood collection tube did you use for this collection?]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="322" y="0" width="222" height="40" uuid="a04caa54-4407-4342-aa73-3440b89bc7dc"/>
				<textElement verticalAlignment="Middle" markup="html">
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{text1_2}+"<br>"]]></textFieldExpression>
			</textField>
		</band>
		<band height="40" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="40" uuid="2e1d9bc6-634d-4e1a-935d-d648d78ae797"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para 3) Is the anticoagulant documented?
<br><font color="#ec6607">shall</font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="22" height="15" uuid="f982f572-2a81-4c7b-a984-79fab187de8b"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[Yes]]></text>
			</staticText>
			<image vAlign="Top">
				<reportElement x="322" y="0" width="10" height="10" uuid="719cd92e-972d-4284-b298-a2585e4fb8cd"/>
				<imageExpression><![CDATA["unchecked.png"]]></imageExpression>
			</image>
