					<font size="12"/>
				</textElement>
				<text><![CDATA[d) RNase-free reagents and consumables were used <br /><br /> <font color="orange"><b>'shall'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="e4b0c406-3f46-4565-91f7-67a026535676"/>
