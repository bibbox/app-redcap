					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[To ensure complete formalin fixation of larger specimens, a special tissue handling such as incision(s) of solid organs or opening of hollow organs was performed]]></text>
			</staticText>
		</band>
