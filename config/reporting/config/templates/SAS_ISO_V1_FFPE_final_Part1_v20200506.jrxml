					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[RNA quantity and quality by one or more of these methods checked (according to manufacturers instructions or validated protocol):]]></text>
			</staticText>
		</band>
		<band height="58" splitType="Prevent">
