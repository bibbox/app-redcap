	<detail>
		<band height="26" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="26" uuid="85b2a9fd-7a35-4cfd-9aa5-13adb12249eb"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Record ID]]></text>
			</staticText>
			<textField isStretchWithOverflow="true">
				<reportElement x="322" y="0" width="222" height="26" uuid="494826fa-73f6-4330-9577-0d8edbcc9ffd"/>
				<textElement textAlignment="Right" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
