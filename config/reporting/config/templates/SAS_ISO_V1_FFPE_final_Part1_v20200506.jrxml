		<band height="78">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="78" uuid="30cc3392-bd95-4414-93af-2068dda4b1c8"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[The storage duration and temperature, typically in ambient temperature in routine archives, influence the RNA stability in FFPE tissue. RNA degradation occurring during storage can have an impact on the validity and reliability of examination test results.]]></text>
			</staticText>
		</band>
		<band height="68" splitType="Prevent">
			<staticText>
				<reportElement x="25" y="0" width="272" height="68" uuid="2b7985bf-4ba8-4936-8cb3-3eecbfdae37b"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
				</textElement>
				<text><![CDATA[para3) Paraffin blocks were stored dry, at or below room temperature, and this was documented <br /><br /> <font color="blue"><b>'should'</b></font>]]></text>
			</staticText>
			<staticText>
				<reportElement x="335" y="0" width="21" height="16" uuid="5bf2c79b-6b9d-4aab-b560-dbaef872bab5"/>
				<textElement verticalAlignment="Top" markup="html">
					<font size="12"/>
