		<band height="78">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="78" uuid="6c56793a-c889-40e8-b027-cc5742c95e85"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[For the isolation of RNA from a very low number of cells like laser microdissected single cells, different dedicated RNA isolation procedures might be needed. For such sensitive procedures, it is recommended to follow the latest literature and verify and validate the isolation procedure before use.]]></text>
			</staticText>
		</band>
		<band height="54">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="54" uuid="597b7508-458d-4c87-9455-c107c1147a4e"/>
				<textElement verticalAlignment="Middle" markup="html">
					<font size="14" isBold="true" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Bold.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[6.9. Quantity and quality assessment of isolated RNA]]></text>
			</staticText>
		</band>
		<band height="62">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="62" uuid="701ec32b-37dc-4728-9cbe-037c1b1c81f9"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[para1) RNA quality and quantity should be checked according to the diagnsotic kit manaufacturer's instructions, if not available, by generally accepted physical, chemical or biochemical procedures.]]></text>
			</staticText>
		</band>
		<band height="62">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="62" uuid="d3cd08a7-0384-42ec-b32b-4b509542507e"/>
