		<band height="105">
			<staticText>
				<reportElement positionType="Float" x="25" y="0" width="545" height="105" uuid="23acf40a-ab15-4350-8b05-42fc5a714407"/>
				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="html">
					<font size="12" pdfFontName="net/sf/jasperreports/fonts/dejavu/DejaVuSerif-Italic.ttf" isPdfEmbedded="true"/>
				</textElement>
				<text><![CDATA[Freezing of tissue may result in the disruption of cellular membranes and organelles within the tissue. As a consequence, after thawing enzymes may be released and activated which may lead to degradation of RNA. Therefore, the specimen or sample shall not thaw before its homogenous dispersion in lysis buffers containing RNase inhibiting substances.]]></text>
			</staticText>
		</band>
